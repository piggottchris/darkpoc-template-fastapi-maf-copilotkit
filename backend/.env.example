# Required: Anthropic API key for the chat client.
# Reuse the same key as the Claude Agent SDK / factory orchestrator — one vendor, one bill.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the Claude model (default: claude-haiku-4-5)
# Other valid IDs: claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_MODEL=claude-haiku-4-5

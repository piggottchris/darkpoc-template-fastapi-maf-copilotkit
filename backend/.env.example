# Required: Anthropic API key for the chat client.
# Reuse the same key as the Claude Agent SDK / factory orchestrator — one vendor, one bill.
ANTHROPIC_API_KEY=sk-ant-replace-me

# Optional: override the Claude model (default: claude-haiku-4-5)
# Other valid IDs: claude-sonnet-4-6, claude-opus-4-7
ANTHROPIC_MODEL=claude-haiku-4-5

# ──────────────────────────────────────────────────────────────────────────────
# Datadog observability — pre-wired by the factory's Phase H
# ──────────────────────────────────────────────────────────────────────────────
# This POC ships with dd-trace (frontend) + ddtrace + ddtrace.llmobs (backend)
# pre-installed. Setting DD_API_KEY enables live ingest; leaving it unset
# leaves the SDKs initialised but inert (safe for offline dev).
#
# The factory seeds these as repo Actions secrets at scaffold time so the
# CI / deploy paths can read them without per-developer setup. Locally,
# fill them in below to see traces / logs / LLM Obs spans for your dev runs.

DD_API_KEY=
# DD_APP_KEY is only needed for dashboard / metric provisioning; safe to
# leave blank for read-only POC instrumentation.
DD_APP_KEY=
# Regional ingest host — must match where your DD account lives.
# Common values: datadoghq.com (US1), datadoghq.eu (EU), us3.datadoghq.com.
DD_SITE=datadoghq.eu
# Logical environment tag. Use `dev` locally, `prod` for deployed instances.
DD_ENV=dev
# Service tag stamped on every span. Override per POC.
DD_SERVICE=darkpoc-backend
# Stamp the running version into traces + logs so DD can correlate
# regressions against deploys.
DD_VERSION=0.1.0
# Set to 1 to enable DD's LLM Observability product (Anthropic SDK calls
# captured as spans with prompt + completion + token counts + latency).
# Leave unset / 0 for traces-only.
DD_LLMOBS_ENABLED=1
